# Chorale environment — copy to `.env` and fill in what you use.
# Local models (Ollama/LM Studio/vLLM) need no key — they use a sentinel value in config.

# Anthropic (swap-in cloud provider)
ANTHROPIC_API_KEY=

# Serverless OpenAI-compatible providers (optional)
FIREWORKS_API_KEY=
HF_TOKEN=

# Web search for the Research agent. Free tier at https://tavily.com (AI-oriented
# search that returns page content). Without it, research falls back to scraping
# DuckDuckGo, which is unreliable and often rate-limited.
TAVILY_API_KEY=

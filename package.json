{
  "name": "chorale",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Model-agnostic multi-agent chorale — a local, open-source Claude Desktop replacement.",
  "bin": {
    "chorale": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@ai-sdk/anthropic": "latest",
    "@ai-sdk/openai-compatible": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "latest",
    "better-sqlite3": "^12.11.1",
    "dotenv": "latest",
    "esbuild": "^0.28.1",
    "gray-matter": "latest",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "json5": "latest",
    "react": "^19.2.7",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

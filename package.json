{
  "name": "chorale",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Model-agnostic multi-agent chorale — a local, open-source Claude Desktop replacement.",
  "bin": {
    "chorale": "./dist/index.js"
  },
  "main": "desktop/dist/main.cjs",
  "build": {
    "appId": "com.chorale.desktop",
    "productName": "Chorale",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "defaults/config"
      },
      {
        "from": "agents",
        "to": "defaults/agents",
        "filter": [
          "**/*.md"
        ]
      },
      {
        "from": ".env.example",
        "to": "defaults/.env.example"
      }
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Chorale-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ui:build": "node desktop/build-main.mjs && vite build --config desktop/vite.config.ts",
    "ui:dev": "node desktop/dev.mjs",
    "ui": "npm run ui:build && electron desktop/dist/main.cjs",
    "pack": "npm run ui:build && electron-builder --dir",
    "dist": "npm run ui:build && electron-builder"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/openai-compatible": "^3.0.9",
    "@heyputer/puter.js": "^2.5.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.26",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "html-to-docx": "^1.8.0",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "json5": "^2.2.3",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "officeparser": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "ssh2": "^1.17.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
